class Solution {
    public static int removeDuplicates(int[] nums) {
        int rd=0;
        for(int i=0;i<nums.length;i++){
            if(nums[rd]!=nums[i]){
                rd++;
                nums[rd]=nums[i];
            }

        }
        return rd+1;
    }
    public static void main(String args[]){
        int nums[]={1,1,2};
        int result=removeDuplicates(nums);
        System.out.print(result);
    }
}
