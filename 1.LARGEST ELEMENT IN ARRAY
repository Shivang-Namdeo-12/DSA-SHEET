class Solution {
    public static  int largestElement(int[] nums) {
        int largest=nums[0];
    for(int i =0;i<nums.length;i++){
        if(nums[i]>largest){
            largest=nums[i];
        }
    }
    return largest;
    }
    public static void main(String args[]){
        int nums[]={3,3,6,1};
        int result=largestElement(nums);
        System.out.println(result);
    }
}
