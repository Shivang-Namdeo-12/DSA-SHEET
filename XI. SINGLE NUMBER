class Solution {
    public static int singleNumber(int[] nums) {
        int count = 0;
        for(int i = 0; i < nums.length; i++){
          count =count^nums[i];
    }
    return count;
}
    public static void main(String args[]){
        int nums[]={2,2,1};
        int result=singleNumber(nums);
        System.out.println(result+" ");
        
}
}
